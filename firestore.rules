rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // users/{uid}: 본인 프로필만 접근
    match /users/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow create: if request.auth != null
                    && request.auth.uid == uid
                    && request.resource.data.uid == uid
                    && request.resource.data.email == request.auth.token.email;
      allow update: if request.auth != null && request.auth.uid == uid;
      allow delete: if false;
    }

    // projects/{projectId}
    match /projects/{projectId} {

      // read: 멤버만
      allow read: if request.auth != null
                  && request.auth.uid in resource.data.memberIds;

      // create: 본인이 owner + memberIds + memberNames 필수
      allow create: if request.auth != null
                    && request.auth.uid == request.resource.data.ownerId
                    && request.auth.uid in request.resource.data.memberIds
                    && request.resource.data.memberNames[request.auth.uid] is string;

      // update: owner 전체 / 멤버는 자기 이름 수정 한정 / 비멤버가 토큰으로 참여 시 멤버 추가 한정
      allow update: if request.auth != null
                    && (
                      // owner 전체 권한
                      request.auth.uid == resource.data.ownerId
                      // 멤버가 자기 이름만 수정 (memberNames[본인uid])
                      || (
                        request.auth.uid in resource.data.memberIds
                        && request.resource.data.ownerId == resource.data.ownerId
                        && request.resource.data.memberIds == resource.data.memberIds
                        && request.resource.data.name == resource.data.name
                        && request.resource.data.startDate == resource.data.startDate
                        && request.resource.data.endDate == resource.data.endDate
                        && request.resource.data.createdAt == resource.data.createdAt
                        && request.resource.data.get('editorIds', []) == resource.data.get('editorIds', [])
                      )
                      // 비멤버가 초대 토큰 사용 시 자기 uid + 자기 이름만 추가
                      || (
                        !(request.auth.uid in resource.data.memberIds)
                        && request.auth.uid in request.resource.data.memberIds
                        && request.resource.data.ownerId == resource.data.ownerId
                        && request.resource.data.name == resource.data.name
                        && request.resource.data.startDate == resource.data.startDate
                        && request.resource.data.endDate == resource.data.endDate
                        && request.resource.data.createdAt == resource.data.createdAt
                        && request.resource.data.get('editorIds', []) == resource.data.get('editorIds', [])
                      )
                    );

      // delete: owner만
      allow delete: if request.auth != null && request.auth.uid == resource.data.ownerId;

      // projects/{projectId}/records/{recordId}
      match /records/{recordId} {
        function isMember() {
          return request.auth != null
                 && get(/databases/$(database)/documents/projects/$(projectId)).data.memberIds.hasAny([request.auth.uid]);
        }
        function isOwner() {
          return request.auth != null
                 && request.auth.uid == get(/databases/$(database)/documents/projects/$(projectId)).data.ownerId;
        }
        function isAllEditor() {
          return request.auth != null
                 && get(/databases/$(database)/documents/projects/$(projectId)).data.get('editorIds', []).hasAny([request.auth.uid]);
        }

        allow read: if isMember();
        allow create: if isMember() && request.auth.uid == request.resource.data.createdBy;
        allow update: if isOwner() || isAllEditor() || (isMember() && request.auth.uid == resource.data.createdBy);
        allow delete: if isOwner() || isAllEditor() || (isMember() && request.auth.uid == resource.data.createdBy);
      }

      // projects/{projectId}/inviteTokens/{token}
      match /inviteTokens/{token} {
        function isOwner() {
          return request.auth != null
                 && request.auth.uid == get(/databases/$(database)/documents/projects/$(projectId)).data.ownerId;
        }
        function isMember() {
          return request.auth != null
                 && get(/databases/$(database)/documents/projects/$(projectId)).data.memberIds.hasAny([request.auth.uid]);
        }

        // read: 로그인한 누구나 (토큰 검증용 -- 토큰 값 알면 접근)
        allow read: if request.auth != null;
        allow create: if isOwner() && request.resource.data.createdBy == request.auth.uid;
        allow update: if
          // owner가 revoke
          (isOwner() && request.resource.data.projectId == resource.data.projectId)
          // 토큰 사용 시 useCount 증가만 (비멤버가 수락 플로우에서)
          || (
            request.auth != null
            && !resource.data.revoked
            && resource.data.expiresAt.toMillis() > request.time.toMillis()
            && request.resource.data.revoked == false
            && request.resource.data.projectId == resource.data.projectId
            && request.resource.data.createdBy == resource.data.createdBy
            && request.resource.data.createdAt == resource.data.createdAt
            && request.resource.data.expiresAt == resource.data.expiresAt
            && request.resource.data.useCount == resource.data.useCount + 1
          );
        allow delete: if isOwner();
      }
    }
  }
}
