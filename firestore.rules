rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // users/{uid}: 본인 프로필만 접근
    match /users/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow create: if request.auth != null
                    && request.auth.uid == uid
                    && request.resource.data.uid == uid
                    && request.resource.data.email == request.auth.token.email;
      allow update: if request.auth != null && request.auth.uid == uid;
      allow delete: if false;
    }

    // projects/{projectId}
    match /projects/{projectId} {

      // read: 멤버이거나 초대받은 상태
      allow read: if request.auth != null
                  && (
                    request.auth.uid in resource.data.memberIds
                    || request.auth.token.email in resource.data.invitedMemberEmails
                  );

      // create: 본인이 owner이고 memberIds에 본인 포함 + memberNames에 본인 포함
      allow create: if request.auth != null
                    && request.auth.uid == request.resource.data.ownerId
                    && request.auth.uid in request.resource.data.memberIds
                    && request.resource.data.memberNames[request.auth.uid] is string;

      // update: owner 전체 가능 / 초대받은 사용자는 자기 uid 추가(수락) 한정
      allow update: if request.auth != null
                    && (
                      request.auth.uid == resource.data.ownerId
                      || (
                        request.auth.token.email in resource.data.invitedMemberEmails
                        && request.resource.data.ownerId == resource.data.ownerId
                        && request.resource.data.name == resource.data.name
                        && request.resource.data.createdAt == resource.data.createdAt
                        && request.resource.data.startDate == resource.data.startDate
                        && request.resource.data.endDate == resource.data.endDate
                        && request.auth.uid in request.resource.data.memberIds
                        && !(request.auth.token.email in request.resource.data.invitedMemberEmails)
                      )
                    );

      // delete: owner만
      allow delete: if request.auth != null && request.auth.uid == resource.data.ownerId;

      // projects/{projectId}/records/{recordId}: 경비 내역
      match /records/{recordId} {
        function isMember() {
          return request.auth != null
                 && get(/databases/$(database)/documents/projects/$(projectId)).data.memberIds.hasAny([request.auth.uid]);
        }
        function isOwner() {
          return request.auth != null
                 && request.auth.uid == get(/databases/$(database)/documents/projects/$(projectId)).data.ownerId;
        }

        allow read: if isMember();
        allow create: if isMember()
                      && request.auth.uid == request.resource.data.createdBy;
        allow update: if isOwner() || (isMember() && request.auth.uid == resource.data.createdBy);
        allow delete: if isOwner() || (isMember() && request.auth.uid == resource.data.createdBy);
      }
    }
  }
}
