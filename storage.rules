rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // 영수증: receipts/{projectId}/{filename}
    // MVP: 로그인한 사용자만 read/write. 실제 권한 체크는 Firestore records 규칙에서 (멤버만 URL 저장/조회).
    // Post-MVP (판매 전환 시): Multi-tenancy + cross-service IAM 설정해서 엄격한 멤버십 체크로 교체.
    match /receipts/{projectId}/{filename} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
                    && request.resource.size < 10 * 1024 * 1024
                    && (request.resource.contentType.matches('image/.*')
                        || request.resource.contentType == 'application/pdf');
      allow delete: if request.auth != null;
    }
  }
}
